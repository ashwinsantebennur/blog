<p style="color: green"><%= notice %></p>

<% content_for :title, "Posts" %>

<h1>Posts</h1>
<p style="font-weight: bold; font-size: larger;">
  <%= link_to "Create New Post", new_post_path if authenticated? %>
</p>
<div id="posts">
  <% @posts.each do |post| %>
    <div id="<%= dom_id post %>" class="<%= cycle('bg-dark', 'bg-light') %>">
      <div class="post-title">
        <%= link_to post.title, post %>
      </div>
      <div class="post-body">
        <%= truncate(post.body, length: 100) %>
      </div>
      <div class="author-info">
        By: <%= post.author.name %> | 
        Created <%= time_ago_in_words(post.created_at) %> ago | 
        Last updated <%= time_ago_in_words(post.updated_at) %> ago
      </div>
    </div>
  <% end %>
</div>
